          <!-- ─── Step 4: Load audio file ─── -->
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Load Audio File" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import java.nio.file.Files
import java.nio.file.Paths

def audioFilePath = props.get("audio.file") ?: "data/audio/sample-short-5s.raw"
def chunkSize = (props.get("audio.chunk_size_bytes") ?: "6400") as int

def audioBytes = Files.readAllBytes(Paths.get(audioFilePath))
vars.putObject("audioBytes", audioBytes)
vars.put("chunkSize", chunkSize.toString())

def numChunks = (int) Math.ceil(audioBytes.length / (double) chunkSize)
vars.put("numChunks", numChunks.toString())

log.info("Audio loaded: ${audioBytes.length} bytes, ${numChunks} chunks of ${chunkSize} bytes")
SampleResult.setResponseData("Loaded ${audioBytes.length} bytes, ${numChunks} chunks", "UTF-8")
SampleResult.setSuccessful(true)
            </stringProp>
          </JSR223Sampler>
          <hashTree/>

          <!-- Audio chunk send loop -->
          <LoopController guiclass="LoopControlPanel" testclass="LoopController" testname="Audio Chunk Loop" enabled="true">
            <stringProp name="LoopController.loops">${numChunks}</stringProp>
            <boolProp name="LoopController.continue_forever">false</boolProp>
          </LoopController>
          <hashTree>
            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Send Audio Chunk (binary)" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
import eu.luminis.jmeter.wssampler.WebsocketSampler

def audioBytes = vars.getObject("audioBytes") as byte[]
def chunkSize = vars.get("chunkSize") as int
def loopIdx = vars.get("__jm__Audio Chunk Loop__idx") as int

def offset = loopIdx * chunkSize
def remaining = Math.min(chunkSize, audioBytes.length - offset)

if (remaining &lt;= 0) {
    SampleResult.setSuccessful(true)
    SampleResult.setResponseData("No more audio data", "UTF-8")
    return
}

def chunk = new byte[remaining]
System.arraycopy(audioBytes, offset, chunk, 0, remaining)

def field = WebsocketSampler.getDeclaredField("threadLocalCachedConnection")
field.setAccessible(true)
def threadLocal = field.get(null) as ThreadLocal
def wsClient = threadLocal.get()

if (wsClient != null &amp;&amp; wsClient.isConnected()) {
    wsClient.sendBinaryFrame(chunk)
    SampleResult.setSuccessful(true)
    SampleResult.setResponseData("Sent chunk ${loopIdx}: ${remaining} bytes at offset ${offset}", "UTF-8")
    SampleResult.setBytes((long) remaining)
    SampleResult.setSentBytes((long) remaining)
} else {
    SampleResult.setSuccessful(false)
    SampleResult.setResponseData("WebSocket not connected", "UTF-8")
}
              </stringProp>
            </JSR223Sampler>
            <hashTree/>

            <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="Real-time Pacing" enabled="true">
              <stringProp name="ConstantTimer.delay">${__P(audio.chunk_interval_ms,200)}</stringProp>
            </ConstantTimer>
            <hashTree/>
          </hashTree>

