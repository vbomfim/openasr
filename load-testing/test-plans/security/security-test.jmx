          <!-- ─── Step 6: Read responses and count backpressure messages ─── -->
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Read flood responses" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import eu.luminis.jmeter.wssampler.WebsocketSampler
import groovy.json.JsonSlurper

def field = WebsocketSampler.getDeclaredField("threadLocalCachedConnection")
field.setAccessible(true)
def threadLocal = field.get(null) as ThreadLocal
def wsClient = threadLocal.get()

def backpressureCount = 0
def errorCount = 0
def phraseCount = 0
def hypothesisCount = 0
def droppedFrames = 0
def allMessages = []

if (wsClient == null || !wsClient.isConnected()) {
    SampleResult.setSuccessful(true)
    SampleResult.setResponseData("WebSocket disconnected (server may have dropped connection under flood)", "UTF-8")
    vars.put("backpressure_count", "0")
    vars.put("flood_error_count", "0")
    return
}

def deadline = System.currentTimeMillis() + 30000
def done = false

while (!done &amp;&amp; System.currentTimeMillis() &lt; deadline) {
    try {
        def frame = wsClient.receiveText(5000)
        if (frame == null) break

        def text = frame.getText()
        def json = new JsonSlurper().parseText(text)
        allMessages.add(json.type)

        switch (json.type) {
            case "speech.backpressure":
                backpressureCount++
                if (json.payload?.dropped_frames != null) {
                    droppedFrames += json.payload.dropped_frames as int
                }
                log.warn("Backpressure #${backpressureCount}: action=${json.payload?.action}, dropped=${json.payload?.dropped_frames}")
                break
            case "speech.hypothesis":
                hypothesisCount++
                break
            case "speech.phrase":
                phraseCount++
                if (json.payload?.status == "EndOfStream") {
                    done = true
                }
                break
            case "speech.checkpoint":
                done = true
                break
            case "speech.error":
                errorCount++
                log.error("Flood error: ${json.payload?.code} - ${json.payload?.message}")
                break
            default:
                log.info("Flood response: ${json.type}")
        }
    } catch (eu.luminis.websocket.UnexpectedFrameException e) {
        log.info("Non-text frame received during flood read, continuing...")
    } catch (java.net.SocketTimeoutException e) {
        log.info("Read timeout during flood response collection")
        break
    }
}

def summary = """Flood Test Results:
  Messages received: ${allMessages.join(', ')}
  Backpressure signals: ${backpressureCount}
  Dropped frames reported: ${droppedFrames}
  Errors: ${errorCount}
  Hypotheses: ${hypothesisCount}
  Phrases: ${phraseCount}"""

log.info(summary)
SampleResult.setResponseData(summary, "UTF-8")
SampleResult.setSuccessful(true)

vars.put("backpressure_count", backpressureCount.toString())
vars.put("flood_error_count", errorCount.toString())
vars.put("flood_dropped_frames", droppedFrames.toString())
            </stringProp>
          </JSR223Sampler>
          <hashTree>
            <!-- Post-processor: log backpressure metrics -->
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Log Backpressure Metrics" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
def bp = vars.get("backpressure_count") ?: "0"
def errs = vars.get("flood_error_count") ?: "0"
def dropped = vars.get("flood_dropped_frames") ?: "0"
log.info("=== FLOOD METRICS === backpressure=${bp}, errors=${errs}, dropped_frames=${dropped}")
              </stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>

          <!-- ─── Step 7: Close WebSocket ─── -->
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="WS Close" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import eu.luminis.jmeter.wssampler.WebsocketSampler

def field = WebsocketSampler.getDeclaredField("threadLocalCachedConnection")
field.setAccessible(true)
def threadLocal = field.get(null) as ThreadLocal
def wsClient = threadLocal.get()

if (wsClient != null &amp;&amp; wsClient.isConnected()) {
    try {
        wsClient.sendClose(1000, "test complete")
        SampleResult.setSuccessful(true)
        SampleResult.setResponseData("WebSocket closed (1000)", "UTF-8")
    } catch (Exception e) {
        SampleResult.setSuccessful(true)
        SampleResult.setResponseData("Close sent (${e.message})", "UTF-8")
    }
} else {
    SampleResult.setSuccessful(true)
    SampleResult.setResponseData("Already disconnected", "UTF-8")
}
            </stringProp>
          </JSR223Sampler>
          <hashTree/>

        </hashTree>
      </hashTree>

      <!-- Summary Report -->
      <ResultCollector guiclass="SummaryReport" testclass="ResultCollector" testname="Summary Report" enabled="true">
        <boolProp name="ResultCollector.error_logging">false</boolProp>
        <objProp>
          <name>saveConfig</name>
          <value class="SampleSaveConfiguration">
            <time>true</time>
            <latency>true</latency>
            <timestamp>true</timestamp>
            <success>true</success>
            <label>true</label>
            <code>true</code>
            <message>true</message>
            <threadName>true</threadName>
            <assertions>true</assertions>
            <bytes>true</bytes>
            <sentBytes>true</sentBytes>
            <url>true</url>
            <threadCounts>true</threadCounts>
            <connectTime>true</connectTime>
          </value>
        </objProp>
        <stringProp name="filename"></stringProp>
      </ResultCollector>
      <hashTree/>

    </hashTree>
  </hashTree>
</jmeterTestPlan>
