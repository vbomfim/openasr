          <hashTree>
            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Send Flood Frame (binary)" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
import eu.luminis.jmeter.wssampler.WebsocketSampler

def frameSize = 6400
def loopIdx = vars.get("__jm__Flood Loop__idx") as int

// Generate a binary frame of frameSize bytes (synthetic audio data)
def chunk = new byte[frameSize]
new Random().nextBytes(chunk)

def field = WebsocketSampler.getDeclaredField("threadLocalCachedConnection")
field.setAccessible(true)
def threadLocal = field.get(null) as ThreadLocal
def wsClient = threadLocal.get()

if (wsClient != null &amp;&amp; wsClient.isConnected()) {
    try {
        wsClient.sendBinaryFrame(chunk)
        SampleResult.setSuccessful(true)
        SampleResult.setResponseData("Flood frame ${loopIdx}: ${frameSize} bytes", "UTF-8")
        SampleResult.setBytes((long) frameSize)
        SampleResult.setSentBytes((long) frameSize)
    } catch (Exception e) {
        SampleResult.setSuccessful(false)
        SampleResult.setResponseData("Send failed at frame ${loopIdx}: ${e.message}", "UTF-8")
    }
} else {
    SampleResult.setSuccessful(false)
    SampleResult.setResponseData("WebSocket not connected at frame ${loopIdx}", "UTF-8")
}
              </stringProp>
            </JSR223Sampler>
