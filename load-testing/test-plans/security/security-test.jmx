<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="OpenASR Security Test" enabled="true">
      <stringProp name="TestPlan.comments">Security load test: auth brute-force (401/429), legitimate session under attack, message flood with backpressure detection.</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
    </TestPlan>
    <hashTree>

      <!-- ═══ Thread Group 1: Auth Brute-Force Test ═══ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Security - Auth Brute-Force" enabled="true">
        <stringProp name="ThreadGroup.num_threads">15</stringProp>
        <stringProp name="ThreadGroup.ramp_time">5</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">60</stringProp>
        <stringProp name="ThreadGroup.delay">0</stringProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <intProp name="LoopController.loops">-1</intProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>

        <!-- Attempt WS Open with invalid Bearer token -->
        <eu.luminis.jmeter.wssampler.OpenWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.OpenWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.OpenWebSocketSampler" testname="WS Open /transcribe (invalid auth)" enabled="true">
          <stringProp name="server">${__P(target.host,localhost)}</stringProp>
          <stringProp name="port">${__P(target.port,30090)}</stringProp>
          <stringProp name="path">/transcribe</stringProp>
          <boolProp name="TLS">false</boolProp>
          <stringProp name="connectTimeout">5000</stringProp>
          <stringProp name="readTimeout">10000</stringProp>
        </eu.luminis.jmeter.wssampler.OpenWebSocketSampler>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="Invalid Auth Header" enabled="true">
            <collectionProp name="HeaderManager.headers">
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Authorization</stringProp>
                <stringProp name="Header.value">Bearer wrong-key-${__threadNum}</stringProp>
              </elementProp>
            </collectionProp>
          </HeaderManager>
          <hashTree/>

          <!-- Assert: response is 401 OR 429 (both acceptable) -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert 401 or 429" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="48663">401</stringProp>
              <stringProp name="51502">429</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <intProp name="Assertion.test_type">40</intProp>
          </ResponseAssertion>
          <hashTree/>

          <!-- Assert: 101 (WebSocket upgrade) must NOT appear — connection should be rejected -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert NOT 101 (no upgrade)" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="48625">101</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <intProp name="Assertion.test_type">20</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- Small delay between brute-force attempts to avoid OS-level socket exhaustion -->
        <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="Attempt Pacing" enabled="true">
          <stringProp name="ConstantTimer.delay">500</stringProp>
        </ConstantTimer>
